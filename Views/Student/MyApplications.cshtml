@model IEnumerable<SkillMatch.Models.Application>
@{
    ViewData["Title"] = "Nhật ký việc làm của tôi";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 p-4 bg-white">
        <div class="d-flex align-items-center mb-3">
            <div class="bg-primary text-white p-3 rounded-3 me-3">
                <i class="bi bi-kanban fs-3"></i>
            </div>
            <div>
                <h2 class="fw-bold text-dark mb-0">Quản lý các dự án của tôi</h2>
                <p class="text-muted mb-0">Theo dõi tiến độ, trạng thái duyệt đơn ứng tuyển và báo cáo kết quả công việc.</p>
            </div>
        </div>

        <hr />

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-folder-x fs-1 text-muted"></i>
                <p class="text-muted mt-2 italic">Bạn chưa nộp đơn ứng tuyển cho bất kỳ dự án nào.</p>
                <a asp-controller="Jobs" asp-action="Index" class="btn btn-primary btn-sm mt-2 fw-bold">Tìm việc ngay</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle border-start-0 border-end-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 25%">Tên dự án / Công việc</th>
                            <th style="width: 15%">Ngân sách</th>
                            <th style="width: 15%">Ngày nộp đơn</th>
                            <th style="width: 20%">Trạng thái ứng tuyển</th>
                            <th style="width: 15%">Trạng thái công việc</th>
                            <th style="width: 10%" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark">@item.Job?.Title</div>
                                    <small class="text-secondary d-block text-truncate" style="max-width: 250px;">
                                        👉 Thư ứng tuyển: @item.CoverLetter
                                    </small>
                                </td>
                                <td>
                                    <span class="text-success fw-bold">@item.Job?.Budget.ToString("N0") đ</span>
                                </td>
                                <td>
                                    <span class="text-muted small">@item.AppliedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </td>
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-hourglass-split"></i> Chờ doanh nghiệp duyệt</span>
                                    }
                                    else if (item.Status == "Accepted")
                                    {
                                        <span class="badge bg-success px-3 py-2"><i class="bi bi-check-all"></i> Đã được nhận việc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger px-3 py-2"><i class="bi bi-x-circle"></i> Từ chối</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Status == "Accepted")
                                    {
                                        if (item.Job?.Status == "Processing")
                                        {
                                            <span class="badge text-primary bg-primary-subtle border border-primary px-2 py-1 small fw-semibold">
                                                ⚙️ Đang thực hiện
                                            </span>
                                        }
                                        else if (item.Job?.Status == "PendingApproval")
                                        {
                                            <span class="badge text-warning bg-warning-subtle border border-warning px-2 py-1 small fw-semibold">
                                                ⏳ Chờ khách nghiệm thu
                                            </span>
                                        }
                                        else if (item.Job?.Status == "Completed")
                                        {
                                            <span class="badge text-success bg-success-subtle border border-success px-2 py-1 small fw-semibold">
                                                ✅ Đã hoàn thành
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">---</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-2 justify-content-center">
                                        <a asp-controller="Jobs" asp-action="Details" asp-route-id="@item.JobId"
                                           class="btn btn-sm btn-outline-secondary" title="Xem chi tiết dự án">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>

                                        @if (item.Status == "Accepted" && (item.Job?.Status == "Processing" || item.Job?.Status == "PendingApproval"))
{
    var isReSubmit = item.Job?.Status == "PendingApproval";

    <button type="button" class="btn btn-sm @(isReSubmit ? "btn-outline-warning" : "btn-success")" 
            data-bs-toggle="modal" 
            data-bs-target="#submitJobModal-@item.Id" 
            title="@(isReSubmit ? "Cập nhật / Nộp lại link bài" : "Báo cáo hoàn thành & Nộp link bài")">
        <i class="bi @(isReSubmit ? "bi-pencil-square" : "bi-check-lg")"></i>
        @if(isReSubmit) { <span class="ms-1 small">Nộp lại</span> }
    </button>

    <div class="modal fade" id="submitJobModal-@item.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-start">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold @(isReSubmit ? "text-warning" : "text-success")">
                        <i class="bi bi-send-check-fill me-1"></i> @(isReSubmit ? "Cập nhật sản phẩm dự án" : "Gửi sản phẩm dự án")
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-controller="Student" asp-action="CompleteJob" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="applicationId" value="@item.Id" />
                    
                    <div class="modal-body">
                        <div class="mb-2">
                            <label class="fw-semibold text-dark mb-1">Dự án:</label>
                            <p class="text-muted mb-2">@item.Job?.Title</p>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary">
                                Đường dẫn sản phẩm (GitHub, Drive, Figma...) <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-link-45deg"></i></span>
                                <input type="url" name="productUrl" class="form-control" 
                                       placeholder="https://github.com/user/project" 
                                       value="@item.ProductUrl" required />
                            </div>
                            <small class="text-muted d-block mt-1">
                                @(isReSubmit ? "Bạn đang cập nhật lại đường dẫn mới. Hệ thống sẽ ghi đè link cũ." : "Hệ thống sẽ gửi link này tới khách hàng để kiểm tra trước khi xác nhận tất toán hợp đồng.")
                            </small>
                        </div>
                    </div>
                    
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-sm @(isReSubmit ? "btn-warning text-dark" : "btn-success") fw-bold px-3">
                            @(isReSubmit ? "Cập nhật sản phẩm" : "Nộp sản phẩm & Đợi duyệt")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>