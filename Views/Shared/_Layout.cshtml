<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkillMatch</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SkillMatch.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-4 py-2.5">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-primary fs-4 d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-lightning-charge-fill me-1"></i> SkillMatch
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1 align-items-center gap-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold px-3 rounded-pill hover-effect" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold px-3 rounded-pill hover-effect" asp-area="" asp-controller="Jobs" asp-action="Index">
                                <i class="bi bi-briefcase me-1"></i> Việc làm SkillMatch
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-semibold px-3 rounded-pill hover-primary-effect" asp-controller="Student" asp-action="Index">
                                    <i class="bi bi-person-badge me-1"></i> Hồ sơ của tôi
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-semibold px-3 rounded-pill hover-primary-effect" asp-controller="Student" asp-action="MyApplications">
                                    <i class="bi bi-send-check me-1"></i> Việc đã ứng tuyển
                                </a>
                            </li>
                        }

                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Client"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-semibold px-3 rounded-pill hover-success-effect" asp-controller="Jobs" asp-action="Create">
                                    <i class="bi bi-plus-circle me-1"></i> Đăng việc mới
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-success fw-semibold px-3 rounded-pill hover-success-effect" asp-controller="Jobs" asp-action="Manage">
                                    <i class="bi bi-kanban me-1"></i> Quản lý dự án
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center gap-2">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-dark me-2 d-flex align-items-center">
                                    <i class="bi bi-person-circle text-secondary me-1.5 fs-5"></i>
                                    Chào, <span class="text-dark fw-bold ms-1">@User.Identity.Name</span>
                                    <span class="badge @(User.IsInRole("Client") ? "bg-success" : "bg-primary") px-2.5 py-1.5 rounded-pill font-monospace ms-2" style="font-size: 11px;">
                                        <i class="@(User.IsInRole("Client") ? "bi bi-building" : "bi bi-mortarboard-fill") me-1"></i>@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                    </span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm px-3.5 py-1.5 fw-bold rounded-pill" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-semibold px-3 rounded-pill hover-effect" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-success btn-sm text-white px-4 py-1.5 fw-bold rounded-pill shadow-sm" asp-controller="Account" asp-action="Register">
                                    Đăng ký
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 py-4 bg-light">
        <div class="container text-center text-secondary small">
            &copy; 2026 - <strong class="text-dark">SkillMatch Project</strong> - Kết nối năng lực sinh viên thực tế
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<style>
    .hover-effect:hover {
        background-color: #f8f9fa;
        color: #0d6efd !important;
    }

    .hover-primary-effect:hover {
        background-color: #e7f1ff;
        color: #0b5ed7 !important;
    }

    .hover-success-effect:hover {
        background-color: #e8f5e9;
        color: #157347 !important;
    }

    .navbar-nav .nav-link {
        transition: all 0.2s ease-in-out;
    }
</style>