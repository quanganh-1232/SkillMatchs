@{
    ViewData["Title"] = "SkillMatch - Nền tảng kết nối nhân sự & dự án tài năng";
    bool isClientHome = ViewBag.IsClientHome ?? false;
    string currentSearch = ViewBag.CurrentSearch ?? "";
    
    // Ép kiểu danh sách tường minh từ ViewBag để tránh lỗi Dynamic
    var students = ViewBag.StudentsList as List<SkillMatch.Models.User> ?? new List<SkillMatch.Models.User>();
    var jobs = ViewBag.JobsList as List<SkillMatch.Models.Job> ?? new List<SkillMatch.Models.Job>();
    var globalMessages = ViewBag.GlobalMessages as List<SkillMatch.Models.ChatMessage> ?? new List<SkillMatch.Models.ChatMessage>();
    int myUserId = ViewBag.CurrentUserId != null ? (int)ViewBag.CurrentUserId : 0;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/font/bootstrap-icons.min.css">

<style>
    body { background-color: #f4f6f9; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .bg-skillmatch-hero { background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%); border-radius: 0 0 24px 24px; }
    
    /* Giao diện Thẻ Việc Làm & Thẻ Sinh Viên Đồng Bộ */
    .card-img-cover { position: relative; height: 140px; overflow: hidden; border-radius: 14px 14px 0 0; background-color: #eaedf2; }
    .card-img-cover img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
    .custom-premium-card:hover .card-img-cover img { transform: scale(1.06); }
    
    .custom-premium-card { transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); border: none !important; border-radius: 14px; background: #ffffff; display: flex; flex-direction: column; height: 100%; overflow: hidden; }
    .custom-premium-card:hover { transform: translateY(-5px); box-shadow: 0 12px 25px rgba(0,0,0,0.08) !important; }
    
    /* Khối Avatar đè lên ảnh bìa của thẻ ứng viên */
    .student-avatar-overlap { position: absolute; bottom: -25px; left: 20px; z-index: 2; }
    .student-avatar-overlap img { width: 60px; height: 60px; border-radius: 50%; object-fit: cover; border: 3px solid #ffffff; box-shadow: 0 4px 8px rgba(0,0,0,0.1); background-color: #fff; }
    
    .badge-top-left { position: absolute; top: 12px; left: 12px; background-color: #ff6b00; color: white; font-weight: 700; font-size: 11px; padding: 5px 10px; border-radius: 6px; text-transform: uppercase; box-shadow: 0 2px 8px rgba(255, 107, 0, 0.4); z-index: 3; }
    .badge-top-right { position: absolute; top: 12px; right: 12px; background-color: #0d6efd; color: white; font-size: 11px; padding: 5px 10px; border-radius: 6px; font-weight: 600; box-shadow: 0 2px 8px rgba(13, 110, 253, 0.3); z-index: 3; }
    .badge-delivery { position: absolute; top: 12px; right: 12px; background-color: rgba(0, 0, 0, 0.65); color: white; font-size: 11px; padding: 5px 10px; border-radius: 6px; backdrop-filter: blur(4px); }
    
    .text-line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; }
    .text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; }
    .bg-cta-box { background: linear-gradient(135deg, #2575fc 0%, #6a11cb 100%); border-radius: 14px; }
    
    /* Sảnh Chat */
    .chat-card { border: none !important; border-radius: 16px; background: #ffffff; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04); overflow: hidden; }
    .chat-header { background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%); padding: 16px 20px; }
    .chat-box-container { height: 260px; overflow-y: auto; background-color: #f8fafc; padding: 20px; border-bottom: 1px solid #f1f5f9; }
    .chat-bubble { max-width: 75%; font-size: 13.5px; padding: 10px 16px; border-radius: 12px; box-shadow: 0 2px 6px rgba(0,0,0,0.02); line-height: 1.5; }
    .chat-bubble-me { background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%); color: #ffffff; border-bottom-right-radius: 2px; }
    .chat-bubble-other { background-color: #ffffff; color: #1e293b; border-bottom-left-radius: 2px; border: 1px solid #e2e8f0; }
    .chat-input-area { background-color: #ffffff; padding: 12px 20px; }
    .chat-textarea { border: 1px solid #e2e8f0; border-radius: 20px; padding: 10px 20px; font-size: 13.5px; transition: all 0.2s; resize: none; background-color: #f8fafc; }
    .chat-textarea:focus { background-color: #ffffff; border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15); }
    .btn-chat-send { background-color: #4f46e5; color: #ffffff; border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; padding: 0; border: none; transition: all 0.2s; }
    .btn-chat-send:hover { background-color: #4338ca; transform: scale(1.05); color: #ffffff; }
    .hover-effect { transition: all 0.2s ease; }
    .hover-effect:hover { transform: translateX(3px); }
</style>

<div class="bg-skillmatch-hero text-white py-5 mb-4 shadow-sm">
    <div class="container text-center py-2">
        <span class="badge bg-white bg-opacity-25 text-white rounded-pill px-3 py-2 mb-3 small fw-semibold">
            🚀 Nền tảng kết nối dự án thực tế #1 cho Sinh viên
        </span>
        <h1 class="fw-bold mb-2 display-6">
            @(isClientHome ? "Tìm kiếm Nhân lực Sinh viên Chất lượng cao" : "Kết nối tri thức - Khẳng định tài năng")
        </h1>
        <p class="text-white-50 mb-4 mx-auto" style="max-width: 600px; font-size: 15px;">
            @(isClientHome ? "Duyệt qua danh sách hồ sơ sinh viên tài năng phù hợp nhất với các dự án công nghệ của bạn." : "Hàng ngàn dự án hấp dẫn từ các doanh nghiệp đối tác đang chờ đợi kỹ năng của bạn.")
        </p>

        <div class="row justify-content-center">
            <div class="col-lg-9">
                <form asp-controller="Home" asp-action="Index" method="get" class="card p-2 border-0 shadow bg-white rounded-pill">
                    <div class="d-flex align-items-center position-relative m-0 w-100">
                        <i class="bi bi-search position-absolute text-muted" style="left: 20px; font-size: 16px; pointer-events: none;"></i>
                        <input type="text" name="searchString" id="live-search-input" value="@currentSearch"
                               class="form-control border-0 bg-transparent shadow-none" 
                               placeholder="@(isClientHome ? "Tìm kiếm theo từ khóa kỹ năng, mô tả sinh viên (ví dụ: react, designer, nodejs)..." : "Tìm theo tên công việc hoặc từ khóa nội dung...")" 
                               style="padding-left: 48px; padding-right: 120px; color: #334155; font-size: 14px;" />
                        <div class="position-absolute pe-1" style="right: 5px;">
                            <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 fw-bold text-nowrap shadow-sm">
                                Tìm kiếm
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="container">
    
    <div class="row mb-5">
        <div class="col-12">
            <div class="card chat-card">
                <div class="card-header chat-header d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 fw-bold text-white d-flex align-items-center gap-2">
                            <span class="spinner-grow spinner-grow-sm text-warning" role="status"></span>
                            Sảnh Thảo Luận Toàn Hệ Thống
                        </h6>
                        <small class="text-white-50" style="font-size: 12px;">Không gian kết nối, trao đổi trực tiếp giữa Doanh nghiệp và Sinh viên</small>
                    </div>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Chat" asp-action="Index" class="btn btn-sm btn-outline-light rounded-pill px-3 py-1.5" style="font-size: 12px; backdrop-filter: blur(4px);">
                            <i class="bi bi-chat-right-text-fill me-1 text-warning"></i> Tin nhắn riêng
                        </a>
                    }
                </div>

                <div class="chat-box-container" id="chatBox">
                    @if (globalMessages.Any())
                    {
                        @foreach (var msg in globalMessages)
                        {
                            bool isMe = msg.SenderId == myUserId;
                            <div class="d-flex mb-3 @(isMe ? "justify-content-end" : "justify-content-start")">
                                <div style="max-width: 75%; width: 100%;" class="d-flex flex-column @(isMe ? "align-items-end" : "align-items-start")">
                                    @if (!isMe)
                                    {
                                        <small class="text-secondary mb-1 fw-semibold ps-1" style="font-size: 11px;">
                                            @(msg.Sender != null ? (!string.IsNullOrEmpty(msg.Sender.FullName) ? msg.Sender.FullName : msg.Sender.Email) : "Thành viên sảnh")
                                        </small>
                                    }
                                    <div class="chat-bubble @(isMe ? "chat-bubble-me" : "chat-bubble-other")">
                                        <p class="mb-0" style="white-space: pre-wrap;">@msg.MessageContent</p>
                                    </div>
                                    <small class="text-muted mt-1 px-1" style="font-size: 10px;">
                                        @msg.SentAt.ToString("HH:mm")
                                    </small>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div id="noMessageNotice" class="text-center text-muted my-5 py-2">
                            <i class="bi bi-chat-square-dots fs-2 text-indigo mb-2 d-block opacity-50"></i>
                            <small class="d-block text-secondary">Sảnh chung đang trống. Hãy gửi tin nhắn đầu tiên để kết nối ngay!</small>
                        </div>
                    }
                </div>

                <div class="chat-input-area border-top">
                    <div class="d-flex align-items-center gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <textarea class="form-control chat-textarea shadow-none flex-grow-1" id="messageInput" rows="1" placeholder="Nhập nội dung thảo luận... (Nhấn Enter để gửi)" style="height: 42px;"></textarea>
                            <button class="btn-chat-send" type="button" id="sendButton" title="Gửi tin nhắn">
                                <i class="bi bi-send-fill text-white fs-6"></i>
                            </button>
                        }
                        else
                        {
                            <div class="form-control bg-light text-center py-2 small text-secondary border-0 rounded-pill">
                                <i class="bi bi-lock-fill me-1 text-warning"></i> Bạn cần <a asp-controller="Account" asp-action="Login" class="fw-bold text-primary text-decoration-none">Đăng nhập tài khoản</a> để tham gia thảo luận sảnh chung.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-5 pe-lg-4">
            
            @if (isClientHome)
            {
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h3 class="fw-bold text-dark mb-1"><i class="bi bi-people-fill text-primary me-2"></i>Hồ sơ ứng viên sẵn có</h3>
                        <p class="text-muted small mb-0">Danh sách nhân sự trẻ sẵn sàng nhận các gói công việc</p>
                    </div>
                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill fw-semibold">
                        ⭐ <span id="item-count-badge">@students.Count</span> Ứng viên khả dụng
                    </span>
                </div>

                <div id="data-list-container">
                    @if (!students.Any())
                    {
                        <div class="alert alert-secondary text-center py-4 rounded-3">
                            <i class="bi bi-exclamation-circle fs-3 d-block mb-2"></i>
                            Không tìm thấy sinh viên nào khớp với từ khóa tìm kiếm của bạn.
                        </div>
                    }
                    else
                    {
                        <div class="row row-cols-1 row-cols-md-2 g-4">
                            @foreach (var stu in students)
                            {
                                <div class="col data-item-card">
                                    <div class="card custom-premium-card shadow-sm">
                                        <div class="card-img-cover">
                                            <img src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=500&auto=format&fit=crop&q=60" 
                                                 alt="Cover-@stu.FullName" />

                                           
                                            
                                            <div class="student-avatar-overlap">
                                                <img src="@(string.IsNullOrEmpty(stu.Avatar) ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(stu.FullName ?? "ST") + "&background=0D6EFD&color=fff" : stu.Avatar)" 
                                                     onerror="this.onerror=null; this.src='https://api.dicebear.com/7.x/adventurer/svg?seed=SkillMatch';" />
                                            </div>
                                        </div>

                                        <div class="card-body p-3 pt-4 d-flex flex-column">
                                            <div class="mt-2 mb-2">
                                                <span class="badge bg-light text-secondary border border-secondary-subtle small" style="font-size: 11px;">
                                                    <i class="bi bi-person-badge-fill me-1 text-primary"></i>Sinh viên Tài năng
                                                </span>
                                            </div>

                                            <h5 class="fw-bold fs-6 mb-1">
                                                <a asp-controller="Student" asp-action="Profile" asp-route-id="@stu.Id" class="text-decoration-none text-dark hover-primary text-truncate d-block item-title-text">
                                                    @stu.FullName
                                                </a>
                                            </h5>

                                            <p class="text-secondary small mb-3 text-truncate-2 item-desc-text" style="font-size: 13px; height: 40px; text-align: justify;">
                                                @(string.IsNullOrEmpty(stu.Bio) ? "Sinh viên chưa cập nhật thông tin giới thiệu chi tiết bản thân." : stu.Bio)
                                            </p>

                                            <div class="d-flex justify-content-between align-items-center pt-3 border-top mt-auto">
                                                <div class="overflow-hidden me-2">
                                                    <small class="text-muted d-block" style="font-size: 10px; text-transform: uppercase;">Liên hệ</small>
                                                    <span class="text-dark fw-semibold small text-truncate d-block" style="font-size: 11px;" title="@stu.Email">
                                                        <i class="bi bi-envelope-at text-primary me-1"></i>@stu.Email
                                                    </span>
                                                </div>
                                                <div class="text-nowrap text-end">
                                                    <small class="text-muted d-block" style="font-size: 10px; text-transform: uppercase;">Trạng thái</small>
                                                    <span class="badge bg-success-subtle text-success rounded-pill fw-bold" style="font-size: 10px;">Sẵn sàng nhận việc</span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="card-footer bg-transparent border-0 p-3 pt-0">
                                            <a asp-controller="Student" asp-action="Profile" asp-route-id="@stu.Id" class="btn btn-outline-primary btn-sm rounded-pill w-100 fw-bold">
                                                <i class="bi bi-eye-fill me-1"></i> Xem Hồ sơ năng lực
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h3 class="fw-bold text-dark mb-1"><i class="bi bi-grid-1x2-fill text-primary me-2"></i>Dự án đang tuyển dụng</h3>
                        <p class="text-muted small mb-0">Các dự án công việc phù hợp với năng lực sinh viên</p>
                    </div>
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill fw-semibold">
                        🔥 <span id="item-count-badge">@jobs.Count</span> Việc làm mở cửa
                    </span>
                </div>

                <div id="data-list-container">
                    @if (!jobs.Any())
                    {
                        <div class="card p-5 text-center border-0 shadow-sm rounded-4 bg-white w-100">
                            <i class="bi bi-mailbox2 fs-1 text-muted mb-3"></i>
                            <h5 class="fw-bold text-secondary">Chưa có dự án nào khớp với bộ lọc kiếm tìm</h5>
                            <p class="text-muted small">Hãy quay lại sau hoặc thử làm mới từ khóa nhé.</p>
                        </div>
                    }
                    else
                    {
                        <div class="row row-cols-1 row-cols-md-2 g-4">
                            @foreach (var job in jobs)
                            {
                                <div class="col data-item-card">
                                    <div class="card custom-premium-card shadow-sm">
                                        <div class="card-img-cover">
                                            <img src="@(string.IsNullOrEmpty(job.Thumbnail) ? "/images/default-thumbnail.jpg" : job.Thumbnail)"
                                                 alt="@job.Title"
                                                 onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=500&auto=format&fit=crop&q=60';" />

                                            @if (job.IsFeatured)
                                            {
                                                <div class="badge-top-left"><i class="bi bi-fire"></i> Nổi bật</div>
                                            }

                                            @if (!string.IsNullOrEmpty(job.DeliveryTime))
                                            {
                                                <div class="badge-delivery"><i class="bi bi-lightning-auto"></i> @job.DeliveryTime</div>
                                            }
                                        </div>

                                        <div class="card-body p-3 d-flex flex-column">
                                            <div class="mb-2">
                                                <span class="badge bg-light text-primary border border-primary-subtle">
                                                    <i class="bi bi-tag-fill me-1"></i>@(job.Category?.Name ?? "Dự án đối tác")
                                                </span>
                                            </div>

                                            <h5 class="fw-bold fs-6 mb-2">
                                                <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id" class="text-decoration-none text-dark hover-primary text-truncate-2 item-title-text">
                                                    @job.Title
                                                </a>
                                            </h5>

                                            <p class="text-secondary small mb-3 text-truncate-2 item-desc-text" style="font-size: 13px;">
                                                @job.Description
                                            </p>

                                            <div class="d-flex justify-content-between align-items-center pt-3 border-top mt-auto">
                                                <div>
                                                    <small class="text-muted d-block" style="font-size: 10px; text-transform: uppercase;">Ngân sách</small>
                                                    <strong class="text-success fs-6 fw-bold">@job.Budget.ToString("N0") đ</strong>
                                                </div>
                                                <div>
                                                    <small class="text-muted d-block text-end" style="font-size: 10px; text-transform: uppercase;">Hạn chót</small>
                                                    <span class="text-dark fw-semibold small" style="font-size: 12px;"><i class="bi bi-clock text-danger me-1"></i>@job.Deadline.ToString("dd/MM")</span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="card-footer bg-transparent border-0 p-3 pt-0">
                                            <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id" class="btn btn-outline-primary btn-sm rounded-pill w-100 fw-bold">
                                                Xem chi tiết & Ứng tuyển
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-lg-4 mb-5">
            @if (User.IsInRole("Client"))
            {
                <div class="card bg-cta-box text-white p-4 border-0 shadow-sm mb-4">
                    <h5 class="fw-bold mb-1"><i class="bi bi-lightning-fill text-warning me-1"></i>Yêu cầu nhân sự gấp?</h5>
                    <p class="text-white-50 small mb-3">Đăng tin tuyển dụng và thiết lập ngân sách dự án ngay để hệ thống tự động gợi ý hồ sơ sinh viên phù hợp.</p>
                    <a asp-controller="Jobs" asp-action="Create" class="btn bg-white text-primary fw-bold w-100 rounded-pill py-2 shadow-sm text-center text-decoration-none">
                        <i class="bi bi-plus-lg me-1"></i> Tạo một tin dự án mới
                    </a>
                </div>
            }

            <div class="card border-0 shadow-sm p-4 bg-white rounded-4 mb-4">
                <h5 class="fw-bold text-dark mb-3"><i class="bi bi-shield-check text-success me-2"></i>Quy trình SkillMatch</h5>
                <div class="d-flex flex-column gap-3 small text-secondary">
                    <div class="d-flex gap-2">
                        <i class="bi bi-1-circle-fill text-primary fs-5"></i>
                        <div><strong>Đăng tin / Duyệt hồ sơ:</strong> Khách đăng việc, duyệt sinh viên hoặc chủ động liên hệ tài năng trước.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <i class="bi bi-2-circle-fill text-primary fs-5"></i>
                        <div><strong>Triển khai công việc:</strong> Kết nối qua hệ thống, thực hiện dự án bám sát mốc tiến độ đặt ra.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <i class="bi bi-3-circle-fill text-primary fs-5"></i>
                        <div><strong>Nghiệm thu an toàn:</strong> Khách kiểm tra sản phẩm hoàn thiện, đánh giá số sao năng lực uy tín.</div>
                    </div>
                </div>
            </div>

            @if (isClientHome)
            {
                var featuredFaces = ViewBag.FeaturedFaces as List<SkillMatch.Models.User>;
                if (featuredFaces != null && featuredFaces.Any())
                {
                    <div class="mb-3">
                        <h5 class="fw-bold text-dark mb-1"><i class="bi bi-star-fill text-warning me-2"></i>Gương mặt xuất sắc</h5>
                    </div>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var student in featuredFaces)
                        {
                            <div class="card p-2 border-0 shadow-sm rounded-3 bg-white hover-effect">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=@(Uri.EscapeDataString(student.FullName))" class="rounded-circle bg-light" style="width:35px;height:35px; object-fit: cover;" alt="" />
                                    <div class="text-truncate">
                                        <a asp-controller="Student" asp-action="Profile" asp-route-id="@student.Id" class="fw-bold d-block text-dark text-truncate text-decoration-none hover-primary" style="font-size: 13.5px;">
                                            @student.FullName
                                        </a>
                                        <span class="text-muted" style="font-size:11px;">🏆 Gương mặt tiêu biểu</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                var topClients = ViewBag.TopClients as List<SkillMatch.Models.User>;
                // Chú ý: Đoạn ép kiểu TopClients nếu có sử dụng mô hình ViewModel riêng thì giữ nguyên từ phiên bản cũ của bạn
                if (topClients != null && topClients.Any())
                {
                    <div class="mb-3">
                        <h5 class="fw-bold text-dark mb-1"><i class="bi bi-fire text-danger me-2"></i>Khách hàng tiềm năng</h5>
                    </div>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var client in topClients)
                        {
                            <div class="card p-2 border-0 shadow-sm rounded-3 bg-white">
                                <div class="d-flex align-items-center justify-content-between gap-2">
                                    <div class="d-flex align-items-center gap-2 text-truncate">
                                        <img src="https://api.dicebear.com/7.x/identicon/svg?seed=@(Uri.EscapeDataString(client.FullName))" class="rounded-3 bg-light" style="width:35px;height:35px;" alt="" />
                                        <div class="text-truncate">
                                            <small class="fw-bold d-block text-dark text-truncate">@client.FullName</small>
                                            <span class="text-muted" style="font-size:11px;">💼 Đối tác uy tín</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        function escapeHtml(text) {
            if (!text) return "";
            return text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
        }

        document.addEventListener("DOMContentLoaded", function () {
            const chatBox = document.getElementById("chatBox");
            if (chatBox) { chatBox.scrollTop = chatBox.scrollHeight; }

            const jobId = "0"; 
            const currentUserId = parseInt("@ViewBag.CurrentUserId") || 0;
            const currentUserName = "@Html.Raw(ViewBag.CurrentUserName ?? "Ẩn danh")";
            const msgInput = document.getElementById("messageInput");

            if (msgInput) {
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/chatHub")
                    .build();

                connection.on("ReceiveMessage", function (senderId, senderName, message, timeStr, channelId) {
                    if (channelId && String(channelId).toLowerCase() !== "global" && String(channelId) !== "0") return;

                    const noMsgNotice = document.getElementById("noMessageNotice");
                    if (noMsgNotice) { noMsgNotice.remove(); }

                    const isMe = Number(senderId) === currentUserId;
                    const displayName = senderName && senderName.trim() !== "" ? senderName : "Thành viên sảnh";

                    const wrapper = document.createElement("div");
                    wrapper.className = `d-flex mb-3 ${isMe ? "justify-content-end" : "justify-content-start"}`;

                    wrapper.innerHTML = `
                        <div style="max-width: 75%; width: 100%;" class="d-flex flex-column ${isMe ? "align-items-end" : "align-items-start"}">
                            ${!isMe ? `<small class="text-secondary mb-1 fw-semibold ps-1" style="font-size: 11px;">${escapeHtml(displayName)}</small>` : ''}
                            <div class="chat-bubble ${isMe ? 'chat-bubble-me' : 'chat-bubble-other'}">
                                <p class="mb-0" style="white-space: pre-wrap;">${escapeHtml(message)}</p>
                            </div>
                            <small class="text-muted mt-1 px-1" style="font-size: 10px;">${timeStr}</small>
                        </div>
                    `;

                    chatBox.appendChild(wrapper);
                    chatBox.scrollTop = chatBox.scrollHeight;
                });

                connection.start().then(function () {
                    connection.invoke("JoinGlobalChat").catch(err => console.error(err.toString()));
                }).catch(err => console.error(err.toString()));

                function sendMsg() {
                    const txt = msgInput.value.trim();
                    if (txt === "") return;
                    connection.invoke("SendMessage", String(jobId), String(currentUserId), currentUserName, txt)
                        .then(() => { msgInput.value = ""; msgInput.focus(); })
                        .catch(err => console.error(err.toString()));
                }

                document.getElementById("sendButton").addEventListener("click", sendMsg);
                msgInput.addEventListener("keydown", function (e) {
                    if (e.key === "Enter" && !e.shiftKey) {
                        e.preventDefault();
                        sendMsg();
                    }
                });
            }

            // Logic Live-Search lọc dữ liệu động
            const searchInput = document.getElementById("live-search-input");
            const listContainer = document.getElementById("data-list-container");
            const countBadge = document.getElementById("item-count-badge");

            if (searchInput && listContainer) {
                const allItems = Array.from(listContainer.querySelectorAll(".data-item-card"));

                searchInput.addEventListener("input", function () {
                    const keyword = this.value.trim().toLowerCase();
                    let visibleCount = 0;

                    if (keyword === "") {
                        allItems.forEach(item => item.style.display = "block");
                        if (countBadge) countBadge.innerText = allItems.length;
                        const existMsg = document.getElementById("live-search-empty");
                        if (existMsg) existMsg.remove();
                        return;
                    }

                    allItems.forEach(item => {
                        const title = item.querySelector(".item-title-text")?.innerText.toLowerCase() || "";
                        const desc = item.querySelector(".item-desc-text")?.innerText.toLowerCase() || "";
                        
                        if (title.includes(keyword) || desc.includes(keyword)) {
                            item.style.display = "block";
                            visibleCount++;
                        } else {
                            item.style.display = "none";
                        }
                    });

                    if (countBadge) countBadge.innerText = visibleCount;

                    const existMsg = document.getElementById("live-search-empty");
                    if (visibleCount === 0) {
                        if (!existMsg) {
                            const emptyDiv = document.createElement("div");
                            emptyDiv.id = "live-search-empty";
                            emptyDiv.className = "alert alert-secondary text-center py-4 rounded-3 my-2 w-100";
                            emptyDiv.innerHTML = `
                                <i class="bi bi-exclamation-circle fs-3 d-block mb-2"></i>
                                Không tìm thấy bản ghi nào khớp với từ khóa tìm kiếm của bạn.`;
                            listContainer.appendChild(emptyDiv);
                        }
                    } else {
                        if (existMsg) existMsg.remove();
                    }
                });
            }
        });
    </script>
}