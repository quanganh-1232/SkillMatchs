@model IEnumerable<SkillMatch.Models.Job>
@inject SkillMatch.Data.SkillMatchDbContext _context

@{
    ViewData["Title"] = "SkillMatch - Nền tảng dự án & kết nối sinh viên tài năng";

    // Truy vấn danh sách sinh viên tiêu biểu có nhiều lượt ứng tuyển thành công
    var topStudents = _context.Users
                             .Where(u => _context.Applications.Any(a => a.StudentId == u.Id && a.Status == "Accepted"))
                             .Take(4)
                             .ToList();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/font/bootstrap-icons.min.css">
<style>
    body {
        background-color: #f8f9fa;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    /* Banner màu tím chuyển sắc */
    .bg-skillmatch-hero {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    }
    /* Style cho Card việc làm */
    .job-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none !important;
        border-radius: 12px;
        background: #ffffff;
    }

        .job-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
        }
    /* Card sinh viên tiêu biểu */
    .student-card {
        border: none !important;
        border-radius: 14px;
        background: #ffffff;
        transition: all 0.2s ease;
    }

        .student-card:hover {
            box-shadow: 0 8px 20px rgba(79, 70, 229, 0.08) !important;
        }

    .avatar-md {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #e0e7ff;
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    /* Banner phụ kêu gọi đăng việc */
    .bg-cta-box {
        background: linear-gradient(135deg, #2575fc 0%, #6a11cb 100%);
        border-radius: 14px;
    }
</style>

<div class="bg-skillmatch-hero text-white py-5 mb-5 shadow-sm">
    <div class="container text-center py-2">
        <span class="badge bg-white bg-opacity-25 text-white rounded-pill px-3 py-2 mb-3 small fw-semibold">
            🚀 Nền tảng kết nối dự án thực tế #1 cho Sinh viên
        </span>
        <h1 class="fw-bold mb-2 display-6">Kết nối tri thức - Khẳng định tài năng</h1>
        <p class="text-white-50 mb-4 mx-auto" style="max-width: 600px; font-size: 15px;">
            Hàng ngàn dự án hấp dẫn từ các doanh nghiệp đối tác đang chờ đợi kỹ năng của bạn.
        </p>

        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="card p-2 border-0 shadow bg-white rounded-pill">
                    <form method="get" asp-controller="Home" asp-action="Index" class="row g-2 align-items-center m-0">
                        <div class="col position-relative">
                            <i class="bi bi-search position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                            <input type="text" name="searchString" class="form-control border-0 ps-5 bg-transparent shadow-none" placeholder="Tìm kiếm tiêu đề công việc, dự án hoặc từ khóa...">
                        </div>
                        <div class="col-auto d-flex gap-2 pe-1">
                            <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm">
                                <i class="bi bi-search me-1"></i> Tìm kiếm
                            </button>

                            @if (User.IsInRole("Client"))
                            {
                                <a asp-controller="Jobs" asp-action="Create" class="btn btn-success rounded-pill px-4 py-2 fw-bold shadow-sm">
                                    <i class="bi bi-plus-circle-fill me-1"></i> Đăng việc mới
                                </a>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row">

        <div class="col-lg-8 mb-5 pe-lg-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="fw-bold text-dark mb-1"><i class="bi bi-briefcase-fill text-primary me-2"></i>Dự án đang tuyển dụng</h3>
                    <p class="text-muted small mb-0">Các dự án công việc phù hợp với năng lực sinh viên</p>
                </div>
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill fw-semibold">
                    🔥 @(Model?.Count() ?? 0) Công việc khả dụng
                </span>
            </div>

            @if (Model == null || !Model.Any())
            {
                <div class="card p-5 text-center border-0 shadow-sm rounded-4 bg-white">
                    <i class="bi bi-mailbox2 fs-1 text-muted mb-3"></i>
                    <h5 class="fw-bold text-secondary">Chưa có dự án nào được đăng tải</h5>
                    <p class="text-muted small">Hãy quay lại sau hoặc thử làm mới trang chủ nhé.</p>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var job in Model)
                    {
                        <div class="card job-card p-4 shadow-sm">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <div>
                                    <h5 class="fw-bold mb-1">
                                        <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id" class="text-decoration-none text-dark hover-primary text-break">
                                            @job.Title
                                        </a>
                                    </h5>
                                    <div class="text-muted small d-flex gap-3 align-items-center">
                                        <span><i class="bi bi-calendar-event me-1"></i> @job.CreatedAt.ToString("dd/MM/yyyy")</span>
                                        <span><i class="bi bi-tag me-1"></i> Dự án đối tác</span>
                                    </div>
                                </div>
                                <span class="badge px-3 py-2 rounded-pill @(job.Status == "Active" ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">
                                    @(job.Status == "Active" ? "● Đang tuyển" : "Đã dừng tuyển")
                                </span>
                            </div>

                            <p class="text-secondary small mb-3 text-truncate-2" style="white-space: pre-line;">
                                @job.Description
                            </p>

                            <div class="d-flex flex-wrap align-items-center justify-content-between pt-3 border-top mt-auto gap-2">
                                <div class="d-flex gap-4">
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 11px;">Chi phí ngân sách</small>
                                        <strong class="text-success fs-5 fw-bold">@job.Budget.ToString("N0") đ</strong>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 11px;">Hạn chót ứng tuyển</small>
                                        <span class="text-dark fw-semibold small"><i class="bi bi-clock text-danger me-1"></i>@job.Deadline.ToString("dd/MM/yyyy")</span>
                                    </div>
                                </div>

                                <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id" class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-bold">
                                    Xem & Ứng tuyển <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-lg-4 mb-5">

            @if (User.IsInRole("Client"))
            {
                <div class="card bg-cta-box text-white p-4 border-0 shadow-sm mb-4">
                    <h5 class="fw-bold mb-1"><i class="bi bi-lightning-fill text-warning me-1"></i>Bạn muốn tuyển nhân sự?</h5>
                    <p class="text-white-50 small mb-3">Đăng ngay các yêu cầu công việc, bài tập lớn để tiếp cận nguồn lực sinh viên chất lượng cao.</p>
                    <a asp-controller="Jobs" asp-action="Create" class="btn btn-white bg-white text-primary fw-bold w-100 rounded-pill py-2 shadow-sm text-center text-decoration-none">
                        <i class="bi bi-plus-lg me-1"></i> Đăng một dự án mới
                    </a>
                </div>
            }

            <div class="mb-4">
                <h4 class="fw-bold text-dark mb-1"><i class="bi bi-star-fill text-warning me-2"></i>Sinh viên tiêu biểu</h4>
                <p class="text-muted small mb-0">Các gương mặt nhận dự án xuất sắc</p>
            </div>

            @if (!topStudents.Any())
            {
                <div class="card p-4 text-center border-0 shadow-sm bg-white rounded-3">
                    <p class="text-muted small mb-0">Dữ liệu sinh viên xuất sắc đang được cập nhật thêm.</p>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var student in topStudents)
                    {
                        int completedCount = _context.Applications.Count(a => a.StudentId == student.Id && a.Status == "Accepted");

                        <div class="card student-card p-3 shadow-sm bg-white">
                            <div class="d-flex align-items-center gap-3">
                                <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=@student.FullName" class="avatar-md bg-light" alt="Avatar">
                                <div class="flex-grow-1">
                                    <h6 class="fw-bold text-dark mb-0">
                                        <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-dark hover-primary fw-bold">
                                            @student.FullName
                                        </a>
                                    </h6>
                                    <small class="text-muted d-block mb-1">📧 @student.Email</small>

                                    <div class="d-flex align-items-center gap-1.5 mt-1">
                                        <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1" style="font-size: 11px;">
                                            🏆 Đã nhận @completedCount dự án
                                        </span>
                                        <span class="text-warning small ms-2"><i class="bi bi-shield-fill-check"></i> Uy tín</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="card border-0 shadow-sm p-4 bg-white rounded-4 mt-4">
                <h5 class="fw-bold text-dark mb-3">🛠️ Quy trình làm việc</h5>
                <div class="d-flex flex-column gap-3 small text-secondary">
                    <div class="d-flex gap-2">
                        <i class="bi bi-1-circle-fill text-primary fs-5"></i>
                        <div><strong>Ứng tuyển nhanh chóng:</strong> Sinh viên nộp giới thiệu bản thân trực tiếp vào bài đăng việc làm.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <i class="bi bi-2-circle-fill text-primary fs-5"></i>
                        <div><strong>Nhận việc & Triển khai:</strong> Khách hàng phê duyệt hồ sơ và giao dự án chạy thực tế.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <i class="bi bi-3-circle-fill text-primary fs-5"></i>
                        <div><strong>Báo cáo nghiệm thu:</strong> Gửi link kết quả (GitHub, Drive...) để khách hàng kiểm tra tất toán.</div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>