@model SkillMatch.Models.Job
@inject SkillMatch.Data.SkillMatchDbContext _context

@{
    ViewData["Title"] = Model?.Title ?? "Chi tiết công việc";
    var currentUserIdClaim = User.FindFirst("UserId")?.Value;
    int currentUserId = currentUserIdClaim != null ? int.Parse(currentUserIdClaim) : 0;

    // Tự động kiểm tra xem dự án đã quá hạn chót nộp hồ sơ chưa (Đối chiếu thời gian thực tế)
    bool isExpired = Model.Deadline < DateTime.Now;

    // Kiểm tra xem sinh viên hiện tại đã từng nộp đơn ứng tuyển cho dự án này chưa
    var currentApp = _context.Applications.FirstOrDefault(a => a.JobId == Model.Id && a.StudentId == currentUserId);
    bool hasApplied = currentApp != null;

    // Chuẩn hóa chuỗi trạng thái từ DB (chuyển về viết thường để so sánh chính xác tuyệt đối)
    string jobStatus = Model.Status?.ToLower() ?? "";
}

<div class="container mt-5">
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-x-circle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0 p-4 bg-white h-100">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="badge bg-primary px-3 py-2 fs-6">🏷️ @ViewBag.CategoryName</span>

                    <span class="badge px-3 py-2 @(isExpired && jobStatus == "open" ? "bg-danger" : jobStatus == "open" ? "bg-success" : jobStatus == "processing" ? "bg-info" : jobStatus == "pendingapproval" ? "bg-warning text-dark" : "bg-secondary")">
                        @(isExpired && jobStatus == "open" ? "Hết hạn nộp đơn" :
                            jobStatus == "open" ? "Đang tuyển dụng" :
                            jobStatus == "processing" ? "Đang thực hiện" :
                            jobStatus == "pendingapproval" ? "Chờ nghiệm thu" : "Đã kết thúc")
                    </span>
                </div>

                <h2 class="fw-bold text-dark mb-3">@Model.Title</h2>

                <div class="d-flex flex-wrap gap-4 text-muted small mb-4 pb-3 border-bottom">
                    <div><i class="bi bi-person-building me-1"></i> Đối tác: <strong class="text-dark">@ViewBag.ClientName</strong></div>
                    <div><i class="bi bi-calendar-event me-1"></i> Đăng lúc: @Model.CreatedAt.ToString("dd/MM/yyyy")</div>
                </div>

                <h5 class="fw-bold text-secondary mb-3"><i class="bi bi-file-earmark-text-fill me-1"></i> Mô tả chi tiết yêu cầu:</h5>
                <div class="text-dark mb-4" style="white-space: pre-line; line-height: 1.6;">
                    @Model.Description
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 p-4 bg-white mb-4">
                <h5 class="fw-bold text-dark mb-3">Thông tin ngân sách</h5>
                <div class="bg-light p-3 rounded-3 text-center mb-3">
                    <span class="text-secondary small d-block mb-1">Chi phí đề xuất</span>
                    <h3 class="fw-bold text-success mb-0">@Model.Budget.ToString("N0") đ</h3>
                </div>
                <div class="d-flex align-items-center text-muted small">
                    <i class="bi bi-clock-fill me-2 @(isExpired ? "text-danger" : "text-warning")"></i>
                    <span>Hạn chót nộp đơn: <strong class="text-dark">@Model.Deadline.ToString("dd/MM/yyyy")</strong></span>
                </div>
            </div>

            @if (User.IsInRole("Student"))
            {
                if (jobStatus == "open")
                {
                    if (isExpired)
                    {
                        <div class="card p-4 shadow-sm border-0 bg-danger-subtle text-center border-start border-danger border-4">
                            <div class="fw-bold text-danger mb-0">
                                <i class="bi bi-calendar-x-fill me-1"></i> Dự án này đã kết thúc hạn nộp đơn ứng tuyển!
                            </div>
                        </div>
                    }
                    else if (hasApplied)
                    {
                        <div class="card p-4 shadow-sm border-0 bg-info-subtle border-start border-info border-4">
                            <h5 class="text-info-emphasis fw-bold mb-2">📬 Đã nộp hồ sơ</h5>
                            <p class="small text-muted mb-3">
                                Bạn đã gửi đơn ứng tuyển cho dự án này. Trạng thái hiện tại:
                                <span class="badge @(currentApp.Status == "Pending" ? "bg-warning text-dark" : currentApp.Status == "Accepted" ? "bg-success" : "bg-danger")">
                                    @(currentApp.Status == "Pending" ? "Chờ duyệt" : currentApp.Status == "Accepted" ? "Được nhận" : "Từ chối")
                                </span>
                            </p>
                            <div class="bg-white p-2 border rounded small text-secondary" style="white-space: pre-line;">
                                <strong>Thư giới thiệu của bạn:</strong><br />@currentApp.CoverLetter
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="card p-4 shadow-sm border-0 bg-primary-subtle border-start border-primary border-4">
                            <h4 class="text-primary fw-bold mb-3">🚀 Ứng tuyển dự án này</h4>
                            <form asp-action="Apply" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="jobId" value="@Model.Id" />
                                <div class="mb-3">
                                    <label class="form-label fw-semibold small">Giới thiệu bản thân & Kinh nghiệm <span class="text-danger">*</span></label>
                                    <textarea name="coverLetter" class="form-control bg-white" rows="4" placeholder="Ví dụ: Chào anh/chị, em đã có kinh nghiệm..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">Gửi đơn ứng tuyển</button>
                            </form>
                        </div>
                    }
                }
                else if (jobStatus == "processing")
                {
                    <div class="card p-4 shadow-sm border-0 bg-info-subtle text-center border-start border-info border-4">
                        <div class="fw-semibold text-info-emphasis mb-3">
                            <i class="bi bi-info-circle-fill me-1"></i> Dự án đã giao cho bạn và đang tiến hành!
                        </div>
                        <button type="button" class="btn btn-success w-100 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#detailSubmitModal">
                            ✅ Báo cáo hoàn thành & Nộp bài
                        </button>
                    </div>
                }
                else if (jobStatus == "pendingapproval")
                {
                    <div class="card p-4 shadow-sm border-0 bg-warning-subtle text-center border-start border-warning border-4">
                        <div class="fw-semibold text-warning-emphasis mb-0">
                            <i class="bi bi-hourglass-split"></i> Bạn đã nộp báo cáo! Vui lòng chờ khách hàng nghiệm thu.
                        </div>
                        @if (currentApp != null && !string.IsNullOrEmpty(currentApp.ProductUrl))
                        {
                            <div class="mt-3 text-start bg-white p-3 border rounded small">
                                <span class="fw-bold text-secondary d-block mb-1">🔗 Link bạn đã nộp:</span>
                                <a href="@currentApp.ProductUrl" target="_blank" class="text-primary text-break">@currentApp.ProductUrl</a>
                            </div>
                        }
                    </div>
                }
                else if (jobStatus == "completed")
                {
                    <div class="alert alert-success text-center fw-bold mb-0 p-3 shadow-sm">
                        🎉 Dự án đã kết thúc & Nghiệm thu tất toán hoàn tất!
                    </div>
                }
            }
        </div>
    </div>

    @if (User.IsInRole("Student") && jobStatus == "processing")
    {
        <div class="modal fade" id="detailSubmitModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content text-start">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold text-success"><i class="bi bi-send-check-fill me-1"></i> Báo cáo hoàn thành sản phẩm</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-controller="Student" asp-action="CompleteJob" method="post">
                        @Html.AntiForgeryToken()
                        @{
                            int appId = currentApp?.Id ?? 0;
                            var currentUrl = Context.Request.Path + Context.Request.QueryString;
                        }
                        <input type="hidden" name="applicationId" value="@appId" />
                        <input type="hidden" name="returnUrl" value="@currentUrl" />

                        <div class="modal-body">
                            <div class="mb-2">
                                <label class="fw-semibold text-dark mb-1">Dự án thực hiện:</label>
                                <p class="text-muted mb-2">@Model.Title</p>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold text-primary">Đường dẫn sản phẩm <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-link-45deg"></i></span>
                                    <input type="url" name="productUrl" class="form-control" placeholder="https://example.com/your-link" required />
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
                            <button type="submit" class="btn btn-success btn-sm fw-bold">Gửi báo cáo</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    @if (User.IsInRole("Client"))
    {
        <div class="mt-5 border-top pt-4">
            <h4 class="text-success fw-bold mb-3"><i class="bi bi-people-fill me-1"></i> Danh sách sinh viên ứng tuyển dự án này</h4>
            @{
                int currentJobId = Model.Id;
                var rawApplicants = _context.Applications.Where(a => a.JobId == currentJobId).ToList();
                var studentIds = rawApplicants.Select(a => a.StudentId).ToList();
                var usersDict = _context.Users.Where(u => studentIds.Contains(u.Id)).ToDictionary(u => u.Id);
            }

            @if (!rawApplicants.Any())
            {
                <div class="p-4 border rounded text-center bg-white shadow-sm">
                    <p class="text-muted italic mb-0">Chưa có sinh viên nào nộp đơn ứng tuyển công việc này.</p>
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var app in rawApplicants)
                    {
                        var studentName = usersDict.ContainsKey(app.StudentId) ? usersDict[app.StudentId].FullName : "Sinh viên ẩn danh";
                        var studentEmail = usersDict.ContainsKey(app.StudentId) ? usersDict[app.StudentId].Email : "N/A";

                        <div class="col-md-6 mb-3">
                            <div class="card h-100 p-3 shadow-sm border-0 border-start border-info border-4 bg-white">
                                <h5 class="fw-bold text-dark mb-1">@studentName</h5>
                                <p class="text-muted small mb-2">📧 @studentEmail</p>
                                <div class="bg-light p-2 border rounded mb-3 flex-grow-1">
                                    <strong class="small text-secondary d-block mb-1">Thư giới thiệu:</strong>
                                    <span class="text-dark small" style="white-space: pre-line;">@app.CoverLetter</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-auto">
                                    <span class="badge px-3 py-2 @(app.Status == "Accepted" ? "bg-success" : app.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark")">
                                        @(app.Status == "Pending" ? "Chờ duyệt" : app.Status == "Accepted" ? "Đã nhận việc" : "Từ chối")
                                    </span>
                                    @if (jobStatus == "open" && app.Status == "Pending")
                                    {
                                        <form asp-action="AcceptApplicant" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="applicationId" value="@app.Id" />
                                            <button type="submit" class="btn btn-outline-success btn-sm fw-bold px-3">🤝 Giao việc</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>