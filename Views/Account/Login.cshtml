@model SkillMatch.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập SkillMatch";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4 card p-4 shadow-sm">
        <h2 class="text-center text-primary mb-4">Đăng Nhập</h2>
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Email trường / cá nhân</label>
                <input asp-for="Email" class="form-control" placeholder="example@student.edu.vn" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Mật khẩu</label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2">Đăng Nhập</button>
        </form>
        <p class="mt-3 text-center">Chưa có tài khoản? <a asp-action="Register">Đăng ký ngay</a></p>
    </div>
</div>