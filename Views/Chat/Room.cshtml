@model IEnumerable<SkillMatch.Models.ChatMessage>
@{
    ViewData["Title"] = $"Trò chuyện cùng {ViewBag.PartnerName}";
    int myUserId = ViewBag.CurrentUserId != null ? (int)ViewBag.CurrentUserId : 0;
    string myUserName = ViewBag.CurrentUserName as string ?? "Ẩn danh";
    int partnerId = ViewBag.PartnerId != null ? (int)ViewBag.PartnerId : 0;
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0 fw-bold"><i class="bi bi-person-fill text-warning me-2"></i> Trò chuyện riêng: @ViewBag.PartnerName</h5>
                <small class="text-white-50">Cuộc hội thoại bảo mật trực tuyến giữa bạn và đối tác</small>
            </div>
            <a asp-controller="Chat" asp-action="Index" class="btn btn-sm btn-light rounded-pill fw-bold">
                <i class="bi bi-arrow-left"></i> Trở lại hộp thư
            </a>
        </div>

        <div class="card-body bg-light position-relative p-4" id="chatBox" style="height: 450px; overflow-y: auto;">
            @if (Model != null && Model.Any())
            {
                @foreach (var msg in Model)
                {
                    bool isMe = msg.SenderId == myUserId;
                    <div class="d-flex mb-3 @(isMe ? "justify-content-end" : "justify-content-start")">
                        <div class="max-width-75" style="max-width: 75%;">
                            <div class="p-3 rounded-3 shadow-sm @(isMe ? "bg-primary text-white rounded-end-0" : "bg-white text-dark rounded-start-0")">
                                <p class="mb-0 small" style="white-space: pre-wrap;">@msg.MessageContent</p>
                            </div>
                            <small class="text-muted d-block mt-1 @(isMe ? "text-end" : "text-start")" style="font-size: 10px;">
                                @msg.SentAt.ToString("HH:mm")
                            </small>
                        </div>
                    </div>
                }
            }
            else
            {
                <div id="noMessageNotice" class="text-center text-muted my-5">
                    <i class="bi bi-chat-quote fs-1 d-block mb-2"></i>
                    Bắt đầu gửi tin nhắn đầu tiên để mở màn cuộc hội thoại!
                </div>
            }
        </div>

        <div class="card-footer bg-white border-0 p-3">
            <div class="input-group">
                <textarea class="form-control border-2 shadow-none" id="messageInput" rows="1" placeholder="Nhập tin nhắn cá nhân..." style="resize: none;"></textarea>
                <button class="btn btn-primary px-4 fw-bold" type="button" id="sendButton">
                    Gửi <i class="bi bi-send-fill ms-1"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        function escapeHtml(text) {
            if (!text) return "";
            return text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
        }

        document.addEventListener("DOMContentLoaded", function () {
            const chatBox = document.getElementById("chatBox");
            if (chatBox) { chatBox.scrollTop = chatBox.scrollHeight; }

            const currentUserId = parseInt("@ViewBag.CurrentUserId") || 0;
            const currentUserName = "@Html.Raw(ViewBag.CurrentUserName ?? "Ẩn danh")";
            const partnerId = parseInt("@ViewBag.PartnerId") || 0;

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .build();

            connection.on("ReceiveMessage", function (senderId, senderName, message, timeStr, channelId) {
                // Chỉ nhận tin nhắn nếu channelId trùng khớp với Id của bạn đời chat hoặc chính mình
                if (Number(channelId) !== currentUserId && Number(channelId) !== partnerId) return;

                const noMsgNotice = document.getElementById("noMessageNotice");
                if (noMsgNotice) { noMsgNotice.remove(); }

                const isMe = Number(senderId) === currentUserId;

                const messageWrapper = document.createElement("div");
                messageWrapper.className = `d-flex mb-3 ${isMe ? "justify-content-end" : "justify-content-start"}`;
                messageWrapper.innerHTML = `
                    <div class="max-width-75" style="max-width: 75%;">
                        <div class="p-3 rounded-3 shadow-sm ${isMe ? 'bg-primary text-white rounded-end-0' : 'bg-white text-dark rounded-start-0'}">
                            <p class="mb-0 small" style="white-space: pre-wrap;">${escapeHtml(message)}</p>
                        </div>
                        <small class="text-muted d-block mt-1 ${isMe ? 'text-end' : 'text-start'}" style="font-size: 10px;">${timeStr}</small>
                    </div>
                `;

                if (chatBox) {
                    chatBox.appendChild(messageWrapper);
                    chatBox.scrollTop = chatBox.scrollHeight;
                }
            });

            connection.on("ReceiveSystemWarning", function (warningMessage) {
                alert("⚠️ " + warningMessage);
            });

            connection.start().then(function () {
                // Kích hoạt lắng nghe phòng 1-1 riêng biệt định danh 2 tài khoản
                connection.invoke("JoinPrivateChat", String(currentUserId), String(partnerId)).catch(err => console.error(err));
            }).catch(err => console.error(err));

            function sendMessageAction() {
                const msgInput = document.getElementById("messageInput");
                if (!msgInput) return;
                const msgText = msgInput.value.trim();
                if (msgText === "") return;

                // Gửi tin với receiverId chính xác là partnerId
                connection.invoke("SendMessage", String(partnerId), String(currentUserId), currentUserName, msgText)
                    .then(() => {
                        msgInput.value = "";
                        msgInput.focus();
                    }).catch(err => console.error(err));
            }

            document.getElementById("sendButton")?.addEventListener("click", sendMessageAction);
            document.getElementById("messageInput")?.addEventListener("keydown", function (e) {
                if (e.key === "Enter" && !e.shiftKey) {
                    e.preventDefault();
                    sendMessageAction();
                }
            });
        });
    </script>
}